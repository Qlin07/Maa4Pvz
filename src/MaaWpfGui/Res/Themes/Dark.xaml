<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 暗色主题颜色 -->
    <Color x:Key="PrimaryColor">#4285F4</Color>
    <Color x:Key="DangerColor">#E03E3E</Color>
    <Color x:Key="SuccessColor">#3EB489</Color>
    <Color x:Key="WarningColor">#E8A838</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />

    <!-- 背景色 -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#1E1E1E" />
    <SolidColorBrush x:Key="RegionBrush" Color="#2D2D2D" />
    <SolidColorBrush x:Key="RegionBrushOpacity25" Color="#08FFFFFF" />
    <SolidColorBrush x:Key="HoverBrush" Color="#0AFFFFFF" />
    <SolidColorBrush x:Key="SelectedBrush" Color="#12FFFFFF" />
    <SolidColorBrush x:Key="BorderBrush" Color="#3D3D3D" />

    <!-- 文字色 -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#E0E0E0" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#9E9E9E" />
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#616161" />

    <!-- 分割线 -->
    <SolidColorBrush x:Key="DividerBrush" Color="#3D3D3D" />
</ResourceDictionary>
