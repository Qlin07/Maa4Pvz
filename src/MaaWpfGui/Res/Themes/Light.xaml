<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- 亮色主题颜色 -->
    <Color x:Key="PrimaryColor">#4285F4</Color>
    <Color x:Key="DangerColor">#E03E3E</Color>
    <Color x:Key="SuccessColor">#3EB489</Color>
    <Color x:Key="WarningColor">#E8A838</Color>

    <SolidColorBrush x:Key="PrimaryBrush" Color="{StaticResource PrimaryColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}" />
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource WarningColor}" />

    <!-- 背景色 -->
    <SolidColorBrush x:Key="WindowBackgroundBrush" Color="#F5F5F5" />
    <SolidColorBrush x:Key="RegionBrush" Color="#FFFFFF" />
    <SolidColorBrush x:Key="RegionBrushOpacity25" Color="#08000000" />
    <SolidColorBrush x:Key="HoverBrush" Color="#0A000000" />
    <SolidColorBrush x:Key="SelectedBrush" Color="#12000000" />
    <SolidColorBrush x:Key="BorderBrush" Color="#E0E0E0" />

    <!-- 文字色 -->
    <SolidColorBrush x:Key="PrimaryTextBrush" Color="#212121" />
    <SolidColorBrush x:Key="SecondaryTextBrush" Color="#757575" />
    <SolidColorBrush x:Key="DisabledTextBrush" Color="#BDBDBD" />

    <!-- 分割线 -->
    <SolidColorBrush x:Key="DividerBrush" Color="#E0E0E0" />
</ResourceDictionary>
