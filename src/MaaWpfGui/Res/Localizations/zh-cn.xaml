<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <!-- 窗口标题 -->
    <sys:String x:Key="WindowTitle">Maa4Pvz</sys:String>
    <sys:String x:Key="WindowVersion">版本</sys:String>

    <!-- 导航 -->
    <sys:String x:Key="NavigationTaskQueue">任务队列</sys:String>
    <sys:String x:Key="NavigationSettings">设置</sys:String>

    <!-- 任务队列 -->
    <sys:String x:Key="TaskQueue">任务队列</sys:String>
    <sys:String x:Key="LinkStart">开始</sys:String>
    <sys:String x:Key="LinkStop">停止</sys:String>
    <sys:String x:Key="FtCrickets">戴夫杯</sys:String>
    <sys:String x:Key="LinkedCompleted">任务完成</sys:String>
    <sys:String x:Key="TaskError">任务出错</sys:String>
    <sys:String x:Key="Connecting">正在连接设备...</sys:String>
    <sys:String x:Key="Connected">设备已连接</sys:String>
    <sys:String x:Key="ConnectFailed">设备连接失败</sys:String>
    <sys:String x:Key="Disconnected">设备已断开</sys:String>
    <sys:String x:Key="Idle">空闲</sys:String>
    <sys:String x:Key="Running">运行中</sys:String>

    <!-- 日志 -->
    <sys:String x:Key="Log">日志</sys:String>

    <!-- 设置 - 连接 -->
    <sys:String x:Key="ConnectSettings">连接设置</sys:String>
    <sys:String x:Key="AdbPath">ADB路径</sys:String>
    <sys:String x:Key="ConnectAddress">连接地址</sys:String>
    <sys:String x:Key="ConnectConfig">连接配置</sys:String>
    <sys:String x:Key="GeneralConfig">通用</sys:String>
    <sys:String x:Key="ConnectTest">连接测试</sys:String>
    <sys:String x:Key="AutoDetect">自动检测</sys:String>

    <!-- 设置 - 界面 -->
    <sys:String x:Key="GUISettings">界面设置</sys:String>
    <sys:String x:Key="Theme">主题</sys:String>
    <sys:String x:Key="LightTheme">亮色</sys:String>
    <sys:String x:Key="DarkTheme">暗色</sys:String>
    <sys:String x:Key="TopMost">窗口置顶</sys:String>
    <sys:String x:Key="MinimizeToTray">最小化到托盘</sys:String>

    <!-- 设置 - 定时（保留） -->
    <sys:String x:Key="TimerSettings">定时设置</sys:String>
    <sys:String x:Key="TimerEnabled">启用定时</sys:String>

    <!-- 通知 -->
    <sys:String x:Key="NotifyIconTooltip">Maa4Pvz</sys:String>
    <sys:String x:Key="ShowMainWindow">显示主窗口</sys:String>
    <sys:String x:Key="Exit">退出</sys:String>

</ResourceDictionary>
