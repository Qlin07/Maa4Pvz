<UserControl
    x:Class="MaaWpfGui.Views.UI.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:s="https://github.com/canton7/Stylet"
    xmlns:ui_vms="clr-namespace:MaaWpfGui.ViewModels.UI"
    d:DataContext="{d:DesignInstance {x:Type ui_vms:SettingsViewModel}}"
    d:DesignHeight="500"
    d:DesignWidth="620"
    mc:Ignorable="d">

    <ScrollViewer
        HorizontalScrollBarVisibility="Disabled"
        VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="20" MaxWidth="600">

            <!-- 连接设置 -->
            <TextBlock
                Style="{StaticResource SectionHeaderStyle}"
                Text="连接设置" />

            <Border
                Background="{DynamicResource RegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="15">
                <StackPanel>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Text="ADB路径" />
                        <TextBox
                            Grid.Column="1"
                            Text="{Binding AdbPath, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <Grid Margin="0,10,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Text="连接地址" />
                        <TextBox
                            Grid.Column="1"
                            Text="{Binding ConnectAddress, UpdateSourceTrigger=PropertyChanged}" />
                    </Grid>

                    <Grid Margin="0,10,0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Text="连接配置" />
                        <ComboBox
                            Grid.Column="1"
                            ItemsSource="{Binding ConnectConfigList}"
                            SelectedItem="{Binding ConnectConfigName}" />
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button
                            Style="{StaticResource PrimaryButtonStyle}"
                            Content="连接测试"
                            Command="{s:Action ConnectTest}" />
                        <TextBlock
                            Margin="15,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="11"
                            Foreground="{DynamicResource SecondaryTextBrush}"
                            Text="{Binding ConnectionStatus}" />
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- 界面设置 -->
            <TextBlock
                Style="{StaticResource SectionHeaderStyle}"
                Margin="0,20,0,5"
                Text="界面设置" />

            <Border
                Background="{DynamicResource RegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="15">
                <StackPanel>
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="100" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                            Grid.Column="0"
                            VerticalAlignment="Center"
                            Text="主题" />
                        <ComboBox
                            Grid.Column="1"
                            ItemsSource="{Binding ThemeList}"
                            SelectedItem="{Binding SelectedTheme}" />
                    </Grid>

                    <CheckBox
                        Margin="0,10,0,0"
                        Content="窗口置顶"
                        IsChecked="{Binding WindowTopMost}" />

                    <CheckBox
                        Margin="0,8,0,0"
                        Content="最小化到系统托盘"
                        IsChecked="{Binding MinimizeToTray}" />

                    <CheckBox
                        Margin="0,8,0,0"
                        Content="启动后自动开始任务"
                        IsChecked="{Binding AutoStart}" />
                </StackPanel>
            </Border>

            <!-- 定时设置（保留接口） -->
            <TextBlock
                Style="{StaticResource SectionHeaderStyle}"
                Margin="0,20,0,5"
                Text="定时设置" />

            <Border
                Background="{DynamicResource RegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4"
                Padding="15">
                <StackPanel>
                    <CheckBox
                        Content="启用定时执行"
                        IsChecked="{Binding TimerEnabled}" />

                    <StackPanel
                        Orientation="Horizontal"
                        Margin="0,10,0,0"
                        IsEnabled="{Binding TimerEnabled}">
                        <TextBlock
                            VerticalAlignment="Center"
                            Text="执行时间" />
                        <hc:NumericUpDown
                            xmlns:hc="https://handyorg.github.io/handycontrol"
                            Margin="10,0"
                            Minimum="0"
                            Maximum="23"
                            Value="{Binding TimerHour}"
                            Width="80" />
                        <TextBlock
                            VerticalAlignment="Center"
                            Text="时" />
                        <hc:NumericUpDown
                            xmlns:hc="https://handyorg.github.io/handycontrol"
                            Margin="10,0"
                            Minimum="0"
                            Maximum="59"
                            Value="{Binding TimerMinute}"
                            Width="80" />
                        <TextBlock
                            VerticalAlignment="Center"
                            Text="分" />
                    </StackPanel>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
