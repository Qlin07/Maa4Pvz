<UserControl
    x:Class="MaaWpfGui.Views.UI.SettingsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:c="clr-namespace:CalcBinding;assembly=CalcBinding"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:dd="urn:gong-wpf-dragdrop"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:properties="clr-namespace:MaaWpfGui.Styles.Properties"
    xmlns:settings="clr-namespace:MaaWpfGui.Views.UserControl.Settings"
    xmlns:ui_vms="clr-namespace:MaaWpfGui.ViewModels.UI"
    d:Background="White"
    d:DataContext="{d:DesignInstance {x:Type ui_vms:SettingsViewModel}}"
    d:DesignHeight="5000"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="175" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!--  左侧导航栏（搜索 + 分区列表）  -->
        <DockPanel Grid.Column="0" Margin="5">
            <hc:SearchBar
                x:Name="SettingsSearchBar"
                hc:BorderElement.CornerRadius="4,4,0,0"
                DockPanel.Dock="Top"
                Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

            <ListBox
                x:Name="MasterListBox"
                dd:DragDrop.IsDragSource="True"
                dd:DragDrop.IsDropTarget="True"
                hc:BorderElement.CornerRadius="0,0,4,4"
                BorderThickness="1,0,1,1"
                DisplayMemberPath="Display"
                IsSynchronizedWithCurrentItem="true"
                ItemsSource="{Binding Settings}"
                SelectedIndex="{Binding SelectedIndex}">
                <ListBox.ItemContainerStyle>
                    <Style BasedOn="{StaticResource TransparentListBoxItemStyle}" TargetType="ListBoxItem">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsVisibleInSearch}" Value="False">
                                <Setter Property="Visibility" Value="Collapsed" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </DockPanel>

        <hc:ScrollViewer
            x:Name="SettingsScrollViewer"
            Grid.Column="1"
            Margin="20,5"
            HorizontalAlignment="Stretch"
            properties:SearchHighlightBehavior.SearchText="{Binding SearchText}"
            properties:SearchHighlightBehavior.SectionFilter="{Binding Settings}"
            properties:ScrollViewerBinding.DividerVerticalOffsetList="{Binding DividerVerticalOffsetList}"
            properties:ScrollViewerBinding.ExtentHeight="{Binding ScrollExtentHeight}"
            properties:ScrollViewerBinding.VerticalOffset="{Binding ScrollOffset}"
            properties:ScrollViewerBinding.ViewportHeight="{Binding ScrollViewportHeight}"
            IsInertiaEnabled="True"
            PanningMode="Both">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Grid
                    Grid.Row="{c:Binding SwitchConfigurationSetting.Value}"
                    Margin="0,0,0,5"
                    d:Grid.Row="0"
                    Visibility="{c:Binding SwitchConfigurationSetting.IsVisibleInSearch}">
                    <Expander
                        d:IsExpanded="True"
                        Background="Transparent"
                        Header="{Binding SwitchConfigurationSetting.Display}"
                        IsExpanded="{Binding IsSwitchConfigurationExpanded}">
                        <Border
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1,0,1,1"
                            CornerRadius="0,0,4,4">
                            <settings:ConfigurationMgrUserControl Margin="0,20" HorizontalAlignment="Center" />
                        </Border>
                    </Expander>
                </Grid>

                <Grid
                    Grid.Row="{c:Binding ScheduleSettingsSetting.Value}"
                    Margin="0,0,0,5"
                    d:Grid.Row="1"
                    Visibility="{c:Binding ScheduleSettingsSetting.IsVisibleInSearch}">
                    <Expander
                        d:IsExpanded="True"
                        Background="Transparent"
                        Header="{Binding ScheduleSettingsSetting.Display}"
                        IsExpanded="{Binding IsScheduleSettingsExpanded}">
                        <Border
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1,0,1,1"
                            CornerRadius="0,0,4,4">
                            <settings:TimerSettingsUserControl
                                Margin="0,20"
                                HorizontalAlignment="Center"
                                DataContext="{Binding TimerSettings}" />
                        </Border>
                    </Expander>
                </Grid>

                <Grid
                    Grid.Row="{Binding PerformanceSettingsSetting.Value}"
                    Margin="0,0,0,5"
                    d:Grid.Row="2"
                    Visibility="{c:Binding PerformanceSettingsSetting.IsVisibleInSearch}">
                    <Expander
                        d:IsExpanded="True"
                        Background="Transparent"
                        Header="{Binding PerformanceSettingsSetting.Display}"
                        IsExpanded="{Binding IsPerformanceSettingsExpanded}">
                        <Border
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1,0,1,1"
                            CornerRadius="0,0,4,4">
                            <settings:PerformanceUserControl
                                Margin="0,20"
                                HorizontalAlignment="Center"
                                DataContext="{Binding PerformanceSettings}"
                                IsEnabled="{Binding DataContext.Idle, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType=UserControl}}" />
                        </Border>
                    </Expander>
                </Grid>

                <Grid
                    Grid.Row="{Binding GameSettingsSetting.Value}"
                    Margin="0,0,0,5"
                    d:Grid.Row="3"
                    Visibility="{c:Binding GameSettingsSetting.IsVisibleInSearch}">
                    <Expander
                        d:IsExpanded="True"
                        Background="Transparent"
                        Header="{Binding GameSettingsSetting.Display}"
                        IsExpanded="{Binding IsGameSettingsExpanded}">
                        <Border
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1,0,1,1"
                            CornerRadius="0,0,4,4">
                            <settings:GameSettingsUserControl
                                Margin="0,20"
                                HorizontalAlignment="Center"
                                DataContext="{Binding GameSettings}" />
                        </Border>
                    </Expander>
                </Grid>

                <Grid
                    Grid.Row="{Binding ConnectionSettingsSetting.Value}"
                    Margin="0,0,0,5"
                    d:Grid.Row="4"
                    Visibility="{c:Binding ConnectionSettingsSetting.IsVisibleInSearch}">
                    <Expander
                        d:IsExpanded="True"
                        Background="Transparent"
                        Header="{Binding ConnectionSettingsSetting.Display}"
                        IsExpanded="{Binding IsConnectionSettingsExpanded}">
                        <Border
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1,0,1,1"
                            CornerRadius="0,0,4,4">
                            <settings:ConnectSettingsUserControl
                                Margin="0,20"
                                HorizontalAlignment="Center"
                                DataContext="{Binding ConnectSettings}"
                                IsEnabled="{Binding DataContext.Idle, RelativeSource={RelativeSource Mode=FindAncestor, AncestorType={x:Type UserControl}}}" />
                        </Border>
                    </Expander>
                </Grid>

                <Grid
                    Grid.Row="{Binding StartupSettingsSetting.Value}"
                    Margin="0,0,0,5"
                    d:Grid.Row="5"
                    Visibility="{c:Binding StartupSettingsSetting.IsVisibleInSearch}">
                    <Expander
                        d:IsExpanded="True"
                        Background="Transparent"
                        Header="{Binding StartupSettingsSetting.Display}"
                        IsExpanded="{Binding IsStartupSettingsExpanded}">
                        <Border
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1,0,1,1"
                            CornerRadius="0,0,4,4">
                            <settings:StartSettingsUserControl
                                Margin="0,20"
                                HorizontalAlignment="Center"
                                DataContext="{Binding StartSettings}" />
                        </Border>
                    </Expander>
                </Grid>

                <Grid
                    Grid.Row="{Binding RemoteControlSettingsSetting.Value}"
                    Margin="0,0,0,5"
                    d:Grid.Row="6"
                    Visibility="{c:Binding RemoteControlSettingsSetting.IsVisibleInSearch}">
                    <Expander
                        d:IsExpanded="True"
                        Background="Transparent"
                        Header="{Binding RemoteControlSettingsSetting.Display}"
                        IsExpanded="{Binding IsRemoteControlSettingsExpanded}">
                        <Border
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1,0,1,1"
                            CornerRadius="0,0,4,4">
                            <settings:RemoteControlUserControl
                                Margin="0,20"
                                HorizontalAlignment="Center"
                                DataContext="{Binding RemoteControlSettings}" />
                        </Border>
                    </Expander>
                </Grid>

                <Grid
                    Grid.Row="{Binding UiSettingsSetting.Value}"
                    Margin="0,0,0,5"
                    d:Grid.Row="7"
                    Visibility="{c:Binding UiSettingsSetting.IsVisibleInSearch}">
                    <Expander
                        d:IsExpanded="True"
                        Background="Transparent"
                        Header="{Binding UiSettingsSetting.Display}"
                        IsExpanded="{Binding IsUiSettingsExpanded}">
                        <Border
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1,0,1,1"
                            CornerRadius="0,0,4,4">
                            <settings:GuiSettingsUserControl
                                Margin="0,20"
                                HorizontalAlignment="Center"
                                DataContext="{Binding GuiSettings}" />
                        </Border>
                    </Expander>
                </Grid>

                <Grid
                    Grid.Row="{Binding BackgroundSettingsSetting.Value}"
                    Margin="0,0,0,5"
                    d:Grid.Row="8"
                    Visibility="{c:Binding BackgroundSettingsSetting.IsVisibleInSearch}">
                    <Expander
                        d:IsExpanded="True"
                        Background="Transparent"
                        Header="{Binding BackgroundSettingsSetting.Display}"
                        IsExpanded="{Binding IsBackgroundSettingsExpanded}">
                        <Border
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1,0,1,1"
                            CornerRadius="0,0,4,4">
                            <settings:BackgroundSettingsUserControl
                                Margin="0,20"
                                HorizontalAlignment="Center"
                                DataContext="{Binding BackgroundSettings}" />
                        </Border>
                    </Expander>
                </Grid>

                <Grid
                    Grid.Row="{Binding ExternalNotificationSettingsSetting.Value}"
                    Margin="0,0,0,5"
                    d:Grid.Row="9"
                    Visibility="{c:Binding ExternalNotificationSettingsSetting.IsVisibleInSearch}">
                    <Expander
                        d:IsExpanded="True"
                        Background="Transparent"
                        Header="{Binding ExternalNotificationSettingsSetting.Display}"
                        IsExpanded="{Binding IsExternalNotificationSettingsExpanded}">
                        <Border
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1,0,1,1"
                            CornerRadius="0,0,4,4">
                            <settings:ExternalNotificationSettingsUserControl
                                Margin="0,20"
                                HorizontalAlignment="Center"
                                DataContext="{Binding ExternalNotificationSettings}" />
                        </Border>
                    </Expander>
                </Grid>

                <Grid
                    Grid.Row="{Binding HotKeySettingsSetting.Value}"
                    Margin="0,0,0,5"
                    d:Grid.Row="10"
                    Visibility="{c:Binding HotKeySettingsSetting.IsVisibleInSearch}">
                    <Expander
                        d:IsExpanded="True"
                        Background="Transparent"
                        Header="{Binding HotKeySettingsSetting.Display}"
                        IsExpanded="{Binding IsHotKeySettingsExpanded}">
                        <Border
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1,0,1,1"
                            CornerRadius="0,0,4,4">
                            <settings:HotKeySettingsUserControl Margin="0,20" HorizontalAlignment="Center" />
                        </Border>
                    </Expander>
                </Grid>

                <Grid
                    Grid.Row="{Binding AchievementSettingsSetting.Value}"
                    Margin="0,0,0,5"
                    d:Grid.Row="11"
                    Visibility="{c:Binding AchievementSettingsSetting.IsVisibleInSearch}">
                    <Expander
                        d:IsExpanded="True"
                        Background="Transparent"
                        Header="{Binding AchievementSettingsSetting.Display}"
                        IsExpanded="{Binding IsAchievementSettingsExpanded}">
                        <Border
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1,0,1,1"
                            CornerRadius="0,0,4,4">
                            <settings:AchievementSettingsUserControl
                                Margin="0,20"
                                HorizontalAlignment="Center"
                                DataContext="{Binding AchievementSettings}" />
                        </Border>
                    </Expander>
                </Grid>

                <Grid
                    Grid.Row="{Binding UpdateSettingsSetting.Value}"
                    Margin="0,0,0,5"
                    d:Grid.Row="12"
                    Visibility="{c:Binding UpdateSettingsSetting.IsVisibleInSearch}">
                    <Expander
                        d:IsExpanded="True"
                        Background="Transparent"
                        Header="{Binding UpdateSettingsSetting.Display}"
                        IsExpanded="{Binding IsUpdateSettingsExpanded}">
                        <Border
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1,0,1,1"
                            CornerRadius="0,0,4,4">
                            <settings:VersionUpdateSettingsUserControl
                                Margin="0,20"
                                HorizontalAlignment="Center"
                                DataContext="{Binding VersionUpdateSettings}" />
                        </Border>
                    </Expander>
                </Grid>

                <Grid
                    Grid.Row="{Binding IssueReportSetting.Value}"
                    Margin="0,0,0,5"
                    d:Grid.Row="13"
                    Visibility="{c:Binding IssueReportSetting.IsVisibleInSearch}">
                    <Expander
                        d:IsExpanded="True"
                        Background="Transparent"
                        Header="{Binding IssueReportSetting.Display}"
                        IsExpanded="{Binding IsIssueReportExpanded}">
                        <Border
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1,0,1,1"
                            CornerRadius="0,0,4,4">
                            <settings:IssueReportUserControl
                                Margin="0,20"
                                HorizontalAlignment="Center"
                                DataContext="{Binding IssueReportSettings}" />
                        </Border>
                    </Expander>
                </Grid>

                <Grid
                    Grid.Row="{Binding AboutUsSetting.Value}"
                    Margin="0,0,0,5"
                    d:Grid.Row="14"
                    Visibility="{c:Binding AboutUsSetting.IsVisibleInSearch}">
                    <Expander
                        d:IsExpanded="True"
                        Background="Transparent"
                        Header="{Binding AboutUsSetting.Display}"
                        IsExpanded="{Binding IsAboutUsExpanded}">
                        <Border
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1,0,1,1"
                            CornerRadius="0,0,4,4">
                            <settings:AboutUserControl Margin="0,20" HorizontalAlignment="Center" />
                        </Border>
                    </Expander>
                </Grid>
                <!--<Rectangle HorizontalAlignment="Stretch" Fill="{DynamicResource BorderBrush}" Height="1" />-->
            </Grid>
        </hc:ScrollViewer>
    </Grid>
</UserControl>
