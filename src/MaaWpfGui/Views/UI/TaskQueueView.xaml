<UserControl
    x:Class="MaaWpfGui.Views.UI.TaskQueueView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:s="https://github.com/canton7/Stylet"
    xmlns:ui_vms="clr-namespace:MaaWpfGui.ViewModels.UI"
    d:DataContext="{d:DesignInstance {x:Type ui_vms:TaskQueueViewModel}}"
    d:DesignHeight="500"
    d:DesignWidth="620"
    mc:Ignorable="d">
    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 左侧：任务列表 + 操作按钮 -->
        <Grid Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 标题 + 状态 -->
            <Grid Grid.Row="0" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                    Grid.Column="0"
                    FontSize="16"
                    FontWeight="SemiBold"
                    Text="任务队列" />
                <TextBlock
                    Grid.Column="1"
                    VerticalAlignment="Center"
                    FontSize="11"
                    Foreground="{Binding TaskStatusBrush}"
                    Text="{Binding TaskStatusText}" />
            </Grid>

            <!-- 任务列表 -->
            <ListBox
                Grid.Row="1"
                Background="Transparent"
                BorderThickness="1"
                BorderBrush="{DynamicResource BorderBrush}"
                ItemsSource="{Binding TaskItemViewModels}"
                Style="{StaticResource LogListBoxStyle}">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="8,6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <CheckBox
                                Grid.Column="0"
                                IsChecked="{Binding IsEnabled}"
                                VerticalAlignment="Center"
                                Margin="0,0,8,0" />
                            <TextBlock
                                Grid.Column="1"
                                VerticalAlignment="Center"
                                Text="{Binding Name}"
                                FontSize="13" />
                        </Grid>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- 操作按钮 -->
            <StackPanel
                Grid.Row="2"
                Margin="0,10,0,0"
                Orientation="Horizontal">
                <Button
                    Style="{StaticResource PrimaryButtonStyle}"
                    Padding="25,8"
                    Content="&#x25B6;  开始"
                    Command="{s:Action LinkStart}" />
                <Button
                    Style="{StaticResource DangerButtonStyle}"
                    Padding="25,8"
                    Margin="10,0,0,0"
                    Content="&#x25A0;  停止"
                    Command="{s:Action LinkStop}" />
            </StackPanel>

            <!-- 连接状态指示 -->
            <TextBlock
                Grid.Row="3"
                Margin="0,8,0,0"
                FontSize="11"
                Foreground="{DynamicResource SecondaryTextBrush}"
                Text="{Binding Inited, StringFormat='连接状态: {0}'}" />
        </Grid>

        <!-- 右侧：日志面板 -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                Grid.Row="0"
                Margin="0,0,0,10"
                FontSize="16"
                FontWeight="SemiBold"
                Text="日志" />

            <Border
                Grid.Row="1"
                Background="{DynamicResource RegionBrush}"
                BorderBrush="{DynamicResource BorderBrush}"
                BorderThickness="1"
                CornerRadius="4">
                <ListBox
                    ItemsSource="{Binding LogItemViewModels}"
                    Style="{StaticResource LogListBoxStyle}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="4,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock
                                    Grid.Column="0"
                                    Foreground="{DynamicResource SecondaryTextBrush}"
                                    FontSize="11"
                                    Margin="0,0,8,0"
                                    Text="{Binding Time}" />
                                <TextBlock
                                    Grid.Column="1"
                                    Foreground="{Binding Foreground}"
                                    FontSize="11"
                                    Text="{Binding Content}"
                                    TextWrapping="Wrap" />
                            </Grid>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>
    </Grid>
</UserControl>
