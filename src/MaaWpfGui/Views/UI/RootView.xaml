<hc:Window
    x:Class="MaaWpfGui.Views.UI.RootView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:hc="https://handyorg.github.io/handycontrol"
    xmlns:s="https://github.com/canton7/Stylet"
    xmlns:ui_vms="clr-namespace:MaaWpfGui.ViewModels.UI"
    Title="{Binding WindowTitle}"
    Width="800"
    Height="600"
    MinWidth="800"
    MinHeight="600"
    d:DataContext="{d:DesignInstance {x:Type ui_vms:RootViewModel}}"
    Topmost="{Binding IsWindowTopMost}"
    ShowTitle="False"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <hc:Window.NonClientAreaContent>
        <Grid HorizontalAlignment="Stretch">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <StackPanel
                Grid.Column="0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <TextBlock
                    Margin="10,0"
                    FontSize="14"
                    FontWeight="Bold"
                    Foreground="{DynamicResource PrimaryBrush}"
                    Text="{Binding WindowTitle}" />
                <TextBlock
                    VerticalAlignment="Bottom"
                    FontSize="10"
                    Foreground="{DynamicResource SecondaryTextBrush}"
                    Text="{Binding WindowVersionInfo}" />
            </StackPanel>
            <StackPanel
                Grid.Column="2"
                VerticalAlignment="Center"
                Orientation="Horizontal" />
        </Grid>
    </hc:Window.NonClientAreaContent>

    <Grid Background="{DynamicResource WindowBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="180" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- 左侧导航栏 -->
        <Border
            Grid.Column="0"
            Background="{DynamicResource RegionBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Logo 区域 -->
                <TextBlock
                    Grid.Row="0"
                    Margin="15,20,15,15"
                    FontSize="22"
                    FontWeight="Bold"
                    Foreground="{DynamicResource PrimaryBrush}"
                    Text="Maa4Pvz" />

                <!-- 导航菜单 -->
                <StackPanel
                    Grid.Row="1"
                    Margin="0,10,0,0"
                    VerticalAlignment="Top">
                    <RadioButton
                        Style="{StaticResource NavigationButtonStyle}"
                        Checked="TaskQueue_Checked"
                        IsChecked="True"
                        Content="&#xE7F5;  任务队列" />
                    <RadioButton
                        Style="{StaticResource NavigationButtonStyle}"
                        Checked="Settings_Checked"
                        Content="&#xE713;  设置" />
                </StackPanel>

                <!-- 底部状态 -->
                <StackPanel
                    Grid.Row="2"
                    Margin="15,0,15,15"
                    Orientation="Vertical">
                    <Separator Margin="0,0,0,10" />
                    <TextBlock
                        FontSize="11"
                        Foreground="{DynamicResource SecondaryTextBrush}"
                        Text="v0.1.0" />
                </StackPanel>
            </Grid>
        </Border>

        <!-- 右侧内容区域 -->
        <ContentControl
            Grid.Column="1"
            Margin="0"
            s:View.Model="{Binding ActiveItem}" />
    </Grid>
</hc:Window>
